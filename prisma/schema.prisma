generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id             String    @id @default(cuid())
  videoId        String
  status         String    @default("WAITING")
  startTime      DateTime?
  baseTimer      Int
  prolongTime    Int
  silencePeriod  Int
  minWords       Int       @default(1)
  minChars       Int       @default(3)
  minSentences   Int       @default(0)
  antiSpamConfig Int       @default(0)
  lastCommentAt  DateTime?
  lastNCount     Int       @default(3)
  firstNCount    Int       @default(10)
  prizeMain      String?
  prizeLastN     String?
  prizeFirstN    String?
  prizeRandomAll  String?
  randomAllCount  Int       @default(1)
  currency       String    @default("$")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  likeCount      String?
  videoTitle     String?
  viewCount      String?
  keywords       String?
  includeOldComments Boolean @default(false)
  isPinned           Boolean @default(false)
  additionalRules    String?
  uniqueParticipantsCount Int @default(0)
  comments       Comment[]
  winners        Winner[]
}

model Comment {
  id             String   @id @default(cuid())
  gameId         String
  commentId      String
  userId         String
  userName       String
  userProfilePic String?
  text           String
  status         String
  invalidReason  String?
  timestamp      DateTime
  createdAt      DateTime @default(now())
  game           Game     @relation(fields: [gameId], references: [id])

  @@unique([gameId, commentId])
  @@index([gameId, status])
  @@index([gameId, timestamp(sort: Desc)])
}

model Winner {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  userName  String
  category  String
  createdAt DateTime @default(now())
  commentId String?
  game      Game     @relation(fields: [gameId], references: [id])

  @@index([gameId])
}
